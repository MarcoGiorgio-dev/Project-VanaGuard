flowchart TD
    A([Start]) --> B[Initialize Flask & SocketIO]
    B --> C[Start poll_db thread]
    C --> D[Start server on 0.0.0.0]

    subgraph POLL [poll_db thread - every 5s]
        P1[get_charts] --> P2[fetch_latest]
        P2 --> P3[emit sensor_update to all clients]
        P3 --> P4{Error?}
        P4 -->|Yes| P5[Print error]
        P4 -->|No| P6[sleep 5s]
        P5 --> P6
        P6 --> P1
    end

    subgraph DB [Database helpers]
        DB1[get_conn] --> DB2[mysql.connector.connect]
        DB3[fetch_recent limit] --> DB4[SELECT last N rows ORDER BY timestamp DESC]
        DB5[fetch_latest] --> DB6[SELECT last 1 row]
        DB7[generate_chart x y] --> DB8[matplotlib Figure → base64 PNG]
        DB9[get_charts] --> DB3
        DB9 --> DB7
    end

    subgraph ROUTES [HTTP Routes]
        R1[GET /] --> R1A[render home.html]
        R2[GET /yolo/] --> R2A[render yolo.html]
        R3[GET /målinger/] --> R3A[render målinger.html]
        R4[GET /brand_alarm/] --> R4A[render brand_alarm.html]
        R5[GET /index/] --> R5A[render index.html]

        R6[GET /api/data/latest] --> R6A[fetch_latest → JSON]
        R7[GET /api/data/history?limit=N] --> R7A[fetch_recent N → JSON]

        R8[GET /api/alarm] --> R8A[Return alarm state\nupdate last_seen]
        R9[POST /api/alarm] --> R9A[Set alarm on/off in state]

        R10[POST /api/battery] --> R10A[Update battery %\nand last_seen in state]
        R11[GET /api/status] --> R11A{last_seen\nwithin 15s?}
        R11A -->|Yes| R11B[online = True]
        R11A -->|No| R11C[online = False]
        R11B --> R11D[Return alarm, battery,\nonline, latest row]
        R11C --> R11D
    end

    subgraph SOCKET [SocketIO Events]
        S1[on connect] --> S2[emit sensor_update with charts]
        S3[on request_update] --> S4[emit sensor_update with charts]
    end
